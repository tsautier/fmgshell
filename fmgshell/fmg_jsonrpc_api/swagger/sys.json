		},
		{
			"name": "\/sys\/ha\/status",
			"description": "Obtain HA information and status of the system. Read-only." 
		},
		{
			"name": "\/sys\/hitcount",
			"description": "" 
		},
		{
			"name": "\/sys\/login\/challenge",
			"description": "Answer a log in challenge question, used following a login\/user or login\/challenge command." 
		},
		{
			"name": "\/sys\/login\/user",
			"description": "Log into the device with user name and password. A new session cookies will be generated and returned as a property of the response object." 
		},
		{
			"name": "\/sys\/logout",
			"description": "Log out a session." 
		},
		{
			"name": "\/sys\/proxy\/json",
			"description": "Send and receive JSON request to\/from managed devices. The response will be an array of data, one for each queried device." 
		},
		{
			"name": "\/sys\/reboot",
			"description": "Restart FortiManager." 
		},
		{
			"name": "\/sys\/status",
