	"info": {
		"title": "FortiManager JSON API Documentation",
		"description": "Documentation for FortiManager JSON API<br\/><br\/>This module contains APIs to read task database. All APIs for this module are read-only, and under the prefix <b>\/task\/<\/b>.",
