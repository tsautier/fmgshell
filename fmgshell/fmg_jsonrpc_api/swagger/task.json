	],
	"produces": [
		"application\/json" 
	],
	"tags": [
		{
			"name": "\/task\/task",
			"description": "Read-only table containing the 10000 most recent tasks of the system. This table can be used for tracking non-blocking tasks initiated by the Device Manager Command and Security Console modules." 
		},
		{
			"name": "\/task\/task\/line",
			"description": "Read-only table.<br\/><br\/>The lines of a task can be unique identify by a combination of \"name\" and \"vdom\" attributes. As a result, there could be more than one object with the matching name, and only one of the objects will be returned if name is specified in the URL. It is recommended to apply filter on the table instead." 
		},
		{
			"name": "\/task\/task\/line\/history",
			"description": "" 
		}
	],
