        "params": {
          "description": "A structure that holds the parameter values.",
          "items": {
            "properties": {
              "apiver": {
                "description": "Current API version.",
                "enum": [
                  3
                ],
                "type": "number"
              },
              "events": {
                "description": "Events that need to acknowledge.",
                "items": {
                  "properties": {
                    "comment": {
                      "description": "Comments of acknowledgement.",
                      "example": [
                        "Acknowledged."
                      ],
                      "type": "string"
                    },
                    "endpoint-id": {
                      "description": "Endpoint ID. Max length 12 bytes",
                      "example": "epid12345678",
                      "type": "string"
                    },
                    "source-ip": {
                      "description": "Source IP.",
                      "example": "10.0.0.1",
                      "type": "string"
                    }
                  },
                  "type": "object"
                },
                "type": "array"
              },
              "time-range": {
                "description": "Time range for IOC acknowledge.",
                "properties": {
                  "end": {
                    "description": "Ending date time. Consider it following the timezone parameter's, ADOM's or FortiAnalyzer's timezone if timezone info is not specified within time range. Format: 'yyyy-MM-dd'T'HH:mm:ssZ' (RFC 3339) e.g. '2016-10-17T20:45:37-07:00 or 'yyyy-MM-dd HH:mm:ss' e.g. '2016-10-17 20:45:37'",
                    "format": "date-time",
                    "type": "string"
                  },
                  "start": {
                    "description": "Starting date time. Consider it following the timezone parameter's, ADOM's or FortiAnalyzer's timezone if timezone info is not specified within time range. Format: 'yyyy-MM-dd'T'HH:mm:ssZ' (RFC 3339) e.g. '2016-10-17T20:45:37-07:00 or 'yyyy-MM-dd HH:mm:ss' e.g. '2016-10-17 20:45:37'",
                    "format": "date-time",
                    "type": "string"
                  }
                },
                "required": [
                  "start",
                  "end"
                ],
                "type": "object"
              },
              "timezone": {
                "description": "The timezone index or name. Time range in request and date/time if any in response will follow this timezone. See Appendix",
                "type": "string"
              },
              "url": {
                "description": "The resource path to <b>IOC Event Acknowledge</b>.",
                "enum": [
                  "/ioc/adom/<adom-name>/events/ack"
                ],
                "type": "string"
              }
            },
            "required": [
              "url",
              "apiver",
              "events"
            ],
            "type": "object"
          },
          "type": "array"
        },
        "session": {
          "description": "The cookie of an active session in FortiAnalyzer.",
          "type": "string"
        }
      }
    },
